[
  {
    "name": "@snapgridjs/react + dnd + core (own code, brotli)",
    "path": [
      "packages/grid-react/dist/index.mjs",
      "packages/grid-dnd/dist/index.mjs",
      "packages/grid-core/dist/index.mjs"
    ],
    "limit": "18.7 kB"
  },
  {
    "name": "@snapgridjs/dnd (brotli)",
    "path": "packages/grid-dnd/dist/index.mjs",
    "limit": "8.7 kB"
  },
  {
    "name": "@snapgridjs/core (brotli)",
    "path": "packages/grid-core/dist/index.mjs",
    "limit": "3.5 kB"
  },
  {
    "name": "@snapgridjs/extras (brotli)",
    "path": "packages/grid-extras/dist/index.mjs",
    "limit": "1.6 kB"
  },
  {
    "name": "@snapgridjs/svelte shipped source (brotli)",
    "path": ["packages/grid-svelte/dist/**/*.js", "packages/grid-svelte/dist/**/*.svelte"],
    "limit": "20 kB"
  }
]
