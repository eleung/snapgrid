{
  "name": "snapgrid-monorepo",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.30.3",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "pnpm -r build",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "pnpm -r typecheck",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "dev": "pnpm --filter @snapgridjs/docs dev",
    "e2e": "pnpm --filter @snapgridjs/docs e2e",
    "search:sync": "pnpm --filter @snapgridjs/docs search:sync",
    "assets": "pnpm --filter @snapgridjs/docs assets",
    "check:og": "pnpm --filter @snapgridjs/docs check:og",
    "validate": "pnpm typecheck && pnpm lint && pnpm test && pnpm build && pnpm size",
    "size": "size-limit",
    "changeset": "changeset",
    "version-packages": "changeset version && biome check --write packages/*/package.json && pnpm --filter @snapgridjs/docs cards",
    "release": "pnpm build && changeset publish"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.0",
    "@changesets/cli": "^2.31.0",
    "@playwright/test": "1.60.0",
    "@size-limit/file": "^12.1.0",
    "@testing-library/dom": "^10.4.0",
    "@testing-library/react": "^16.1.0",
    "@types/node": "^25.9.3",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "jsdom": "^29.1.1",
    "playwright": "^1.60.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "size-limit": "^12.1.0",
    "tsdown": "^0.22.2",
    "typescript": "^6.0.3",
    "unrun": "^0.3.1",
    "vitest": "^4.1.8"
  }
}
